android_app {
    name: "OpenClawSettings",
    srcs: ["src/**/*.java"],
    sdk_version: "core_platform",
    platform_apis: true,
    certificate: "platform",
    privileged: true,
    libs: ["framework"],
    static_libs: ["tensorflow-lite"],
    manifest: "AndroidManifest.xml",
    resource_dirs: ["res"],
}
